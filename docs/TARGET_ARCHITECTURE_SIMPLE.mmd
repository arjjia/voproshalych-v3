%%{init: {'theme': 'base', 'flowchart': {'defaultRenderer': 'elk', 'curve': 'basis'}} }%%
flowchart LR

    %% ═══════════════════════════════════════════════════════
    %% ЦВЕТОВЫЕ КЛАССЫ (те же, что в MVP + 2 новых)
    %% ═══════════════════════════════════════════════════════
    %% --- Контейнеры Docker (отдельные процессы) ---
    classDef container_if  fill:#E3F2FD,stroke:#1565C0,stroke-width:3px,color:#0D47A1
    classDef container_gw  fill:#FFF3E0,stroke:#E65100,stroke-width:3px,color:#BF360C
    classDef container_br  fill:#E0F7FA,stroke:#006064,stroke-width:3px,color:#004D40
    classDef container_ms  fill:#E8F5E9,stroke:#2E7D32,stroke-width:3px,color:#1B5E20
    classDef container_tl  fill:#E0F2F1,stroke:#00695C,stroke-width:3px,color:#004D40
    classDef container_st  fill:#FFEBEE,stroke:#C62828,stroke-width:3px,color:#B71C1C

    %% --- Внутренние модули (внутри контейнеров) ---
    classDef module        fill:#F1F8E9,stroke:#9CCC65,stroke-width:1px,color:#33691E

    %% --- Не-контейнеры (внешние сущности) ---
    classDef client        fill:#ECEFF1,stroke:#546E7A,stroke-width:2px,color:#263238
    classDef provider      fill:#F3E5F5,stroke:#6A1B9A,stroke-width:2px,color:#4A148C
    classDef external      fill:#FFFDE7,stroke:#F9A825,stroke-width:2px,color:#F57F17

    %% --- Специальные ---
    classDef notmvp        fill:#FAFAFA,stroke:#BDBDBD,stroke-width:1px,stroke-dasharray:5 5,color:#757575
    classDef target        fill:#FFF8E1,stroke:#FF6F00,stroke-width:3px,color:#E65100

    %% --- НОВЫЕ для target ---
    classDef growth        fill:#E8EAF6,stroke:#3F51B5,stroke-width:2px,color:#1A237E
    classDef blocked       fill:#FFCDD2,stroke:#D32F2F,stroke-width:2px,stroke-dasharray:5 5,color:#B71C1C

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 0 — ПОЛЬЗОВАТЕЛЬ (роли: гость → абитуриент → студент → сотрудник)
    %% ═══════════════════════════════════════════════════════
    subgraph UserLayer["👤 Пользователь — единый аккаунт, роли: гость / абитуриент / студент / сотрудник"]
        USER_BR["🌐 Браузер<br/>(desktop / планшет / стенд)"]:::client
        USER_VK["💬 ВКонтакте"]:::client
        USER_MAX["💬 MAX"]:::client
        USER_TG["💬 Telegram 🚀<br/>(M1)"]:::growth
    end

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 1 — КЛИЕНТСКИЕ ИНТЕРФЕЙСЫ
    %% ═══════════════════════════════════════════════════════
    subgraph ClientsLayer["🖥️ Клиентские интерфейсы"]
        subgraph LobeHub["🐳 lobe-chat (:3210)"]
            LOBE["LobeChat v3<br/>server-mode<br/>вкладки: чат, профиль 🚀,<br/>уведомления 🚀"]:::module
            AUTH["Better Auth + SSO<br/>email + OIDC ТюмГУ ⛔<br/>(M1)"]:::blocked
            PROFILE_UI["🔒 Цифровой профиль 🚀<br/>просмотр / редактирование<br/>интересы, цели, достижения (M3)"]:::growth
            NOTIFY_UI["Уведомления 🚀<br/>in-app / email / TG (M3)"]:::growth
            RICH_TRACE["Rich-trace рендер 🚀<br/>мысли, инструменты,<br/>источники (M2)"]:::growth
            LOBE -. "опционально" .-> AUTH
            LOBE --- PROFILE_UI
            LOBE --- NOTIFY_UI
            LOBE --- RICH_TRACE
        end

        BOTVK["🐳 bot-vk"]:::container_br
        BOTMAX["🐳 bot-max"]:::container_br
        BOTTELEGRAM["🐳 bot-telegram 🚀<br/>(M1)"]:::growth
    end

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 2 — AGENT-SERVICE
    %% ═══════════════════════════════════════════════════════
    subgraph AgentService["🐳 agent-service (:8001)"]
        MW["UserIdentityMiddleware<br/>X-User-Id → Profile<br/>+ roles[] 🚀 + scopes[] 🚀"]:::growth

        SAFETY["🛡️ Safety-слой 🚀<br/>тематический фильтр ⛔<br/>кризис-эскалация ⛔<br/>PII / toxicity / anti-injection"]:::blocked

        PROFILE_API["Profile API 🚀<br/>чтение / запись<br/>цифрового профиля (M3)"]:::growth

        subgraph LangGraphGraph["LangGraph StateGraph"]
            SUP["Supervisor<br/>диспетчер: классификация<br/>+ Fast/Deep роутинг 🚀 (M2)<br/>+ role-aware routing 🚀"]:::growth
            KBWF["KB Workflow<br/>вопрос про университет<br/>(правила, стипендии, ...)"]:::module
            META["Meta<br/>вопрос об ассистенте<br/>(«кто ты?», «что умеешь?»)"]:::module
            REACT["ReAct<br/>запрос, требующий инструментов<br/>+ личные scoped-tools 🚀<br/>write: human-in-the-loop ⛔"]:::growth
            CLARIFY["Clarify<br/>запрос неясен"]:::module
            OFFTOPIC["OffTopic<br/>вопрос не про университет"]:::module
        end

        MCPCLI["MCP-клиент<br/>JSON-RPC + user token 🚀"]:::growth
        TRACELOG["trace_logger<br/>+ LangFuse 🚀<br/>rich-trace, evals, spend (M2)"]:::growth

        %% внутренние связи
        MW -- "Profile + roles<br/>+ scopes" --> SAFETY
        SAFETY -- "filtered request" --> SUP
        MW -- "profile R/W" --> PROFILE_API
        MW -- "write trace" --> TRACELOG
        SUP -- "intent: kb_qa" --> KBWF
        SUP -- "intent: meta" --> META
        SUP -- "intent: tool_required" --> REACT
        SUP -- "intent: clarify" --> CLARIFY
        SUP -- "intent: off_topic" --> OFFTOPIC
        KBWF -- "MCP: kb_search" --> MCPCLI
        REACT -- "MCP: public + personal 🚀" --> MCPCLI
        SUP -- "write trace" --> TRACELOG
        KBWF -- "write trace" --> TRACELOG
        REACT -- "write trace" --> TRACELOG
    end

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 3 — MCP-СЕРВЕРЫ
    %% ═══════════════════════════════════════════════════════
    subgraph MCPLayer["🔧 MCP-серверы"]
        MCPKB["🐳 mcp-kb (:9010)<br/>kb_search"]:::container_tl
        MCPNEWS["🐳 mcp-news (:9011)<br/>get_news, get_events"]:::container_tl
        MCPFETCH["🐳 mcp-fetch (:9015)<br/>fetch_url"]:::container_tl

        MCPELECTIVES["🐳 mcp-electives 🚀<br/>выбор элективов (M2)"]:::growth
        MCPCANTEEN["🐳 mcp-canteen 🚀<br/>меню столовых"]:::growth
        MCPAPPLICANT["🐳 mcp-applicant ⛔<br/>поступление (M4)"]:::blocked

        subgraph PersonalMCP["🔒 Личные MCP (scoped, по токену пользователя) ⛔"]
            MCPMODEUS["mcp-modeus ⛔<br/>расписание, оценки (M2)"]:::blocked
            MCPLMS["mcp-lms ⛔<br/>курсы, задания (M2)"]:::blocked
            MCPVMESTE["mcp-vmeste ⛔<br/>общежитие, справки (M3)"]:::blocked
            MCOPEMAIL["mcp-email ⛔<br/>почта (M3)"]:::blocked
        end

        MCPCONTACTS["🐳 mcp-contacts (:9012)<br/>❌ вне MVP"]:::notmvp
        MCPLIB["🐳 mcp-library (:9013)<br/>❌ вне MVP"]:::notmvp
        MCPSVEDEN["🐳 mcp-sveden (:9014)<br/>❌ вне MVP"]:::notmvp
    end

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 4 — KB-SERVICE
    %% ═══════════════════════════════════════════════════════
    subgraph KBService["🐳 kb-service (:8005→8004)"]
        subgraph ParsersGroup["Парсеры (краулеры)"]
            PCONFL["ConfluenceParser<br/>Help + Study"]:::module
            PNEWS["UtmnNewsParser (stories)"]:::module
            PEVENTS["UtmnNewsParser (events)"]:::module
            PUTMN["UtmnParser<br/>❌ вне MVP"]:::notmvp
            PSVEDEN["SvedenParser<br/>❌ вне MVP"]:::notmvp
            PFAQ["UtmnFaqParser<br/>❌ вне MVP"]:::notmvp
            PCONTACTS["UtmnContactsParser<br/>❌ вне MVP"]:::notmvp
        end

        EMB["SentenceTransformer<br/>deepvk/USER-bge-m3, dim=1024"]:::module
        CHUNK["Chunking<br/>max_chars=500, overlap=50"]:::module
        SEARCH["pgvector search<br/>+ реранкер 🚀 + FTS 🚀<br/>workspaces: public, applicant,<br/>student, staff, news_events 🚀<br/>(ПДн не индексируются)"]:::growth

        PCONFL -- "текст" --> CHUNK
        PNEWS -- "текст" --> CHUNK
        PEVENTS -- "текст" --> CHUNK
        CHUNK -- "chunks" --> EMB
        EMB -- "embeddings" --> SEARCH
    end

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 5 — LITELLM
    %% ═══════════════════════════════════════════════════════
    subgraph LiteLLMLayer["🐳 litellm (:4000) — Шлюз"]
        LITELLM["LiteLLM Proxy<br/>маршрутизация, fallback<br/>+ сегрегация: personal →<br/>zero-retention 🚀"]:::growth
    end

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 6 — LLM-ПРОВАЙДЕРЫ
    %% ═══════════════════════════════════════════════════════
    subgraph ProvidersLayer["☁️ LLM-провайдеры (внешние API)"]
        ZEN["OpenCode Zen<br/>free-модели"]:::provider
        MISTRALP["Mistral"]:::provider
        OPENROUTER["OpenRouter"]:::provider
        GIGACHAT["GigaChat 🚀<br/>zero-retention для ПДн"]:::growth
        OLLAMA["Ollama 🚀<br/>local fallback"]:::growth
    end

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 7 — ХРАНИЛИЩА
    %% ═══════════════════════════════════════════════════════
    subgraph StorageLayer["💾 Хранилища и observability"]
        PG["🐳 postgres (:5433)<br/>PG 17 + pgvector + AGE<br/>+ user_profiles 🚀 (M3)<br/>+ audit_log 🚀"]:::container_st
        REDIS["🐳 redis (:6380)<br/>+ Pub/Sub 🚀"]:::container_st
        LANGFUSE["📊 LangFuse 🚀<br/>traces, evals, spend (M2)"]:::growth
        S3["📁 S3 / MinIO 🚀<br/>файлы, ассеты"]:::growth
    end

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 8 — QUEUE / WORKER (НОВЫЙ)
    %% ═══════════════════════════════════════════════════════
    subgraph QueueLayer["📋 Queue / Worker 🚀 (new)"]
        QUEUE["🐳 queue-worker 🚀<br/>daily re-index,<br/>уведомления (M3)"]:::growth
    end

    %% ═══════════════════════════════════════════════════════
    %% СЛОЙ 9 — ВНЕШНИЕ ИСТОЧНИКИ
    %% ═══════════════════════════════════════════════════════
    subgraph ExternalLayer["🌐 Внешние источники и сервисы ТюмГУ"]
        CONFL["Confluence<br/>Help + Study (Vouch SSO)"]:::external
        UTMNNEWS["utmn.ru/news/stories"]:::external
        UTMNEVENTS["utmn.ru/news/events"]:::external
        SSOTYUMNU["SSO ТюмГУ (OIDC) ⛔<br/>корпоративная учётка (M1)"]:::blocked

        subgraph InternalServices["🔒 Внутренние сервисы ТюмГУ (личные данные) ⛔"]
            MODEUS["Modeus ⛔<br/>расписание, оценки"]:::blocked
            LMS["LMS ⛔<br/>курсы, задания, дедлайны"]:::blocked
            VMESTE["«Вместе» ⛔<br/>общежитие, справки"]:::blocked
            YANDEX360["Яндекс 360 ⛔<br/>корп. почта"]:::blocked
        end

        UTMNKONT["utmn.ru/kontakty<br/>❌ вне MVP"]:::notmvp
        BMK["bmk.utmn.ru, lib.utmn.ru<br/>❌ вне MVP"]:::notmvp
        SVEDENEXT["sveden.utmn.ru<br/>❌ вне MVP"]:::notmvp
    end

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: Пользователь → Клиентские интерфейсы
    %% ═══════════════════════════════════════════════════════
    USER_BR -- "HTTP → :3210" --> LOBE
    USER_VK -- "VK API" --> BOTVK
    USER_MAX -- "MAX API" --> BOTMAX
    USER_TG -- "TG API 🚀" --> BOTTELEGRAM
    LOBE -. "HTTP + rich-trace 🚀" .-> USER_BR
    BOTVK -. "исходящее" .-> USER_VK
    BOTMAX -. "исходящее" .-> USER_MAX
    BOTTELEGRAM -. "исходящее 🚀" .-> USER_TG

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: Auth → SSO
    %% ═══════════════════════════════════════════════════════
    AUTH -. "OIDC ⛔" .-> SSOTYUMNU

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: Клиентские интерфейсы → Agent-service (FastAPI)
    %% ═══════════════════════════════════════════════════════
    LOBE -- "POST /v1/chat/completions<br/>(FastAPI)<br/>+ JWT {sub, roles, scopes} 🚀" --> MW
    BOTVK -- "POST /chat (FastAPI)" --> MW
    BOTMAX -- "POST /chat (FastAPI)" --> MW
    BOTTELEGRAM -- "POST /chat 🚀" --> MW
    MW -. "SSE + rich-trace 🚀<br/>+ permission_prompt ⛔" .-> LOBE

    %% LobeHub → PostgreSQL
    LOBE -- "SQL: sessions, messages" --> PG
    AUTH -- "SQL: users, sessions" --> PG
    PROFILE_UI -- "SQL: user_profiles 🚀" --> PG

    %% Profile API → PG
    PROFILE_API -- "SQL: user_profiles 🚀<br/>(roles[], интересы, цели)" --> PG

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: Agent-service → LiteLLM (LLM-вызовы)
    %% ═══════════════════════════════════════════════════════
    SUP -. "LLM: классификация<br/>t=0.1" .-> LITELLM
    KBWF -. "LLM: генерация ответа<br/>t=0.7" .-> LITELLM
    REACT -. "LLM: выбор действия<br/>t=0.3" .-> LITELLM

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: Agent-service → MCP-серверы
    %% ═══════════════════════════════════════════════════════
    MCPCLI -- "JSON-RPC: kb_search" --> MCPKB
    MCPCLI -- "JSON-RPC: news, events" --> MCPNEWS
    MCPCLI -- "JSON-RPC: fetch_url" --> MCPFETCH
    MCPCLI -- "JSON-RPC: electives 🚀" --> MCPELECTIVES
    MCPCLI -- "JSON-RPC: canteen 🚀" --> MCPCANTEEN
    MCPCLI -. "⛔ M4" .-> MCPAPPLICANT
    MCPCLI -. "JSON-RPC + user token ⛔" .-> MCPMODEUS
    MCPCLI -. "JSON-RPC + user token ⛔" .-> MCPLMS
    MCPCLI -. "JSON-RPC + user token ⛔<br/>write: human-in-the-loop" .-> MCPVMESTE
    MCPCLI -. "JSON-RPC + user token ⛔" .-> MCOPEMAIL
    MCPCLI -. "вне MVP" .-> MCPCONTACTS
    MCPCLI -. "вне MVP" .-> MCPLIB
    MCPCLI -. "вне MVP" .-> MCPSVEDEN

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: MCP-серверы → KB-service / Внешние
    %% ═══════════════════════════════════════════════════════
    MCPKB -- "JSON-RPC: kb_search" --> SEARCH
    MCPNEWS -- "HTTP GET" --> UTMNNEWS
    MCPNEWS -- "HTTP GET" --> UTMNEVENTS
    MCPFETCH -- "HTTP GET" --> UTMNNEWS
    MCPMODEUS -. "API ⛔" .-> MODEUS
    MCPLMS -. "API ⛔" .-> LMS
    MCPVMESTE -. "API ⛔" .-> VMESTE
    MCOPEMAIL -. "API ⛔" .-> YANDEX360
    MCPCONTACTS -. "вне MVP" .-> UTMNKONT
    MCPLIB -. "вне MVP" .-> BMK
    MCPSVEDEN -. "вне MVP" .-> SVEDENEXT

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: KB-service → Хранилища и Внешние
    %% ═══════════════════════════════════════════════════════
    SEARCH -- "SQL: cosine + reranker 🚀<br/>WHERE workspace ∈ roles 🚀" --> PG
    PCONFL -- "crawl (с хоста)<br/>Vouch SSO cookie" --> CONFL
    PNEWS -- "HTTP GET" --> UTMNNEWS
    PEVENTS -- "HTTP GET" --> UTMNEVENTS
    PUTMN -. "вне MVP" .-> UTMNNEWS
    PSVEDEN -. "вне MVP" .-> SVEDENEXT

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: LiteLLM → Провайдеры и Redis
    %% ═══════════════════════════════════════════════════════
    LITELLM -- "API: primary + fallback" --> ZEN
    LITELLM -- "API: fallback" --> MISTRALP
    LITELLM -- "API: fallback" --> OPENROUTER
    LITELLM -- "API 🚀" --> GIGACHAT
    LITELLM -- "API 🚀<br/>(local)" --> OLLAMA
    LITELLM -- "usage log<br/>spend tracking" --> PG
    LITELLM -. "cache" .-> REDIS

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: Observability
    %% ═══════════════════════════════════════════════════════
    TRACELOG -. "traces, evals 🚀" .-> LANGFUSE

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: Queue / Worker
    %% ═══════════════════════════════════════════════════════
    QUEUE -- "daily re-index 🚀" --> MCPNEWS
    QUEUE -- "уведомления 🚀<br/>(дедлайны, расписание)" --> NOTIFY_UI

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: Файлы
    %% ═══════════════════════════════════════════════════════
    LOBE -. "файлы (PDF, DOCX) 🚀" .-> S3

    %% ═══════════════════════════════════════════════════════
    %% СВЯЗИ: Trace → PG
    %% ═══════════════════════════════════════════════════════
    TRACELOG -. "🆕 write agent_traces<br/>+ audit_log 🚀" .-> PG
